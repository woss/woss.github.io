    "@tailwindcss/typography": "^0.5.20",
    "ai": "^6.0.207",
    "better-sqlite3": "12.10.0",
    "copy-text-to-clipboard": "^3.2.2",
    "dayjs": "^1.11.21",
    "devalue": "^5.8.1",
    "dotenv": "17.4.2",
    "effect": "^3.21.3",
    "geoip-country": "^5.0.202605270000",
    "github-slugger": "2.0.0",
    "highlight.js": "11.11.1",
    "isbot": "^5.1.43",
    "isomorphic-dompurify": "^3.17.0",
